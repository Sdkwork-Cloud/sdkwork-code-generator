{
  "name": "sdkwork-code-generator",
  "version": "0.1.0",
  "description": "A modern code generator based on OpenAPI 3.x standard, supporting multiple programming languages SDK and HTTP request code generation",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "prepare": "husky install"
  },
  "keywords": [
    "openapi",
    "code-generator",
    "sdk",
    "typescript",
    "mcp",
    "model-context-protocol"
  ],
  "author": "sdkwork-team",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.5",
    "@types/node": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "eslint": "^8.47.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "jest": "^29.6.2",
    "prettier": "^2.8.8",
    "ts-jest": "^29.1.1",
    "typescript": "^5.1.6",
    "vite": "^4.4.9",
    "vite-plugin-dts": "^3.5.2"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "openapi-types": "^12.1.0",
    "yaml": "^2.8.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sdkwork/sdkwork-code-generator.git"
  },
  "bugs": {
    "url": "https://github.com/sdkwork/sdkwork-code-generator/issues"
  },
  "homepage": "https://github.com/sdkwork/sdkwork-code-generator#readme"
}
